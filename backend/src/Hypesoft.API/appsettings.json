{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "System": "Warning"
      }
    }
  },
  "MongoDB": {
    "ConnectionString": "mongodb://mongo:27017",
    "DatabaseName": "hypesoft"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/hypesoft",
    "Audience": "hypesoft-frontend",
    "ValidIssuer": "http://localhost:8080/realms/hypesoft",
    "MetadataAddress": "http://keycloak:8080/realms/hypesoft/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "AllowedHosts": "*"
}
